{
  "expo": {
    "name": "Group Task",
    "slug": "grouptask",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/GTRLOGO.jpeg",
    "userInterfaceStyle": "light", 
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/GTRLOGO.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "grouptask",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.grouptaskmobile",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "grouptask",
              "exp"
            ] 
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/GTRLOGO.jpeg",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yourcompany.grouptaskmobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "grouptask"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        } 
      ]
    },
    "web": {
      "favicon": "./assets/GTRLOGO.jpeg"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "cfac69aa-72f5-4ef5-a8ce-39e531e8897a"
      }
    },
    "owner": "sybeans"
  }
}
