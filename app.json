{
  "expo": {
    "name": "Group Task",
    "slug": "grouptask",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/GTRLOGO.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/GTRLOGO.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "grouptask",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcompany.grouptaskmobile",
      "infoPlist": {
        "UIBackgroundModes": ["remote-notification"],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "grouptask",
              "exp"
            ]
          }
        ]
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/GTRLOGO.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yourcompany.grouptaskmobile",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "grouptask"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/GTRLOGO.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23,
            "targetSdkVersion": 34,
            "compileSdkVersion": 34,
            "buildToolsVersion": "34.0.0",
            "kotlinVersion": "1.9.24"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/GTRLOGO.png",
          "color": "#4F46E5",
          "defaultChannel": "default",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "cfac69aa-72f5-4ef5-a8ce-39e531e8897a"
      }
    },
    "owner": "sybeans"
  }
}